@model GamePageViewModel
@{
    ViewData["Title"] = $"Лобби {Model.Lobby.Code}";
}

<div id="game-app" data-code="@Model.Lobby.Code" data-player-id="@Model.CurrentPlayer.Id">
    <div id="game-header" class="alert mb-3">
        <span id="header-text">Загрузка...</span>
    </div>
    <div id="lobby-content">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Загрузка...</span></div>
        </div>
    </div>
</div>

@section Scripts
{
}
