    window.handleForm = async function(e) {
        e.preventDefault();
        const form = e.target;
        const formData = new FormData(form);
        
        try {
            const response = await fetch(form.action, {
                method: "POST",
                body: formData
            });
            if (response.ok) {
                location.reload();
            } else {
                const data = await response.json();
                if (data.error) {
                    alert(data.error);
                }
            }
        } catch (err) {
            console.error(err);
        }
        return false;
    };
</script>